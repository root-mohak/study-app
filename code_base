function addDeadline() {
  const name = document.getElementById('task-name').value.trim();
  const subject = document.getElementById('task-subject').value.trim();
  const date = document.getElementById('task-date').value;
  const type = document.getElementById('task-type').value;
  const priority = document.getElementById('task-priority').value;
  if (!name) { alert('Enter a task name.'); return; }
  deadlines.push({ id: Date.now(), name, subject, date, type, priority, done: false });
  saveDeadlines();
  document.getElementById('task-name').value = '';
  renderDeadlines();
  updateDashboard();
}
function saveDeadlines() { localStorage.setItem('studyos_deadlines', JSON.stringify(deadlines)); }
function toggleDone(id) {
  const d = deadlines.find(x => x.id === id);
  if (d) { d.done = !d.done; saveDeadlines(); renderDeadlines(); updateDashboard(); }
}
function deleteDeadline(id) {
  deadlines = deadlines.filter(x => x.id !== id);
  saveDeadlines(); renderDeadlines(); updateDashboard();
}
let dlFilter = 'all';
function filterDeadlines(f) { dlFilter = f; renderDeadlines(); }
function renderDeadlines() {
  let list = [...deadlines].sort((a,b) => new Date(a.date)-new Date(b.date));
  if (dlFilter !== 'all') list = list.filter(d => d.type === dlFilter);
  const el = document.getElementById('deadline-list');
  if (!list.length) { el.innerHTML = `<div class="empty"><div class="empty-icon">◻</div><div class="empty-text">No tasks yet — add one above</div></div>`; return; }
  el.innerHTML = list.map(d => {
    const dl = daysLeft(d.date);
    const color = d.done ? 'var(--hint)' : dl <= 0 ? 'var(--red)' : dl <= 3 ? 'var(--amber)' : 'var(--green)';
    const urgency = d.done ? 0 : Math.max(0, Math.min(100, 100 - dl * 8));
    const typeTag = { assignment:'tag-blue', exam:'tag-red', project:'tag-purple', quiz:'tag-amber', other:'tag-muted' };
    const prTag = { high:'tag-red', medium:'tag-amber', low:'tag-green' };
    return `<div class="deadline-row ${d.done?'done':''}">
      <div class="deadline-check ${d.done?'checked':''}" onclick="toggleDone(${d.id})">${d.done?'✓':''}</div>
      <div class="deadline-info">
        <div class="deadline-name">${d.name}</div>
        <div style="display:flex;gap:6px;margin-top:4px;flex-wrap:wrap">
          ${d.subject ? `<span class="tag tag-muted">${d.subject}</span>` : ''}
          <span class="tag ${typeTag[d.type]||'tag-muted'}">${d.type}</span>
          <span class="tag ${prTag[d.priority]||'tag-muted'}">${d.priority}</span>
        </div>
        ${!d.done ? `<div class="urgency-bar" style="width:${urgency}%;background:${color};max-width:200px"></div>` : ''}
      </div>
      <div class="deadline-date" style="color:${color}">
        <div>${d.date || '—'}</div>
        <div style="font-size:11px;margin-top:2px">${d.done ? 'Done' : dl <= 0 ? 'Overdue' : dl === 1 ? 'Tomorrow' : `${dl}d left`}</div>
      </div>
      <button class="deadline-del" onclick="deleteDeadline(${d.id})">×</button>
    </div>`;
  }).join('');
}
renderDeadlines();

// ─────────────────────────────────────────────────────────────────────────────
// PYQ ANALYSER
// ─────────────────────────────────────────────────────────────────────────────
let pyqBase64 = '';
function pyqDrop(e) { e.preventDefault(); if (e.dataTransfer.files[0]) pyqLoad(e.dataTransfer.files[0]); }
function pyqFile(e) { if (e.target.files[0]) pyqLoad(e.target.files[0]); }
function pyqLoad(file) {
  document.getElementById('pyq-filename').textContent = file.name;
  document.getElementById('pyq-zone').classList.add('has-file');
  const r = new FileReader();
  if (file.type === 'application/pdf') {
    r.onload = e => { pyqBase64 = e.target.result.split(',')[1]; pyqFileContent = null; };
    r.readAsDataURL(file);
  } else {
    r.onload = e => { pyqFileContent = e.target.result; pyqBase64 = null; };
    r.readAsText(file);
  }
}
async function analysePYQ() {
  if (!pyqBase64 && !pyqFileContent) { alert('Upload a PYQ file first.'); return; }
  const subject = document.getElementById('pyq-subject').value || 'Engineering';
  const unit = document.getElementById('pyq-unit').value;
  btnLoading('pyq-btn', true);
  document.getElementById('pyq-output').innerHTML = `<div class="card"><div style="color:var(--muted);font-size:13px">Reading and analysing your paper...</div></div>`;
  const sys = `You are a PYQ analyser for Indian engineering exams. Return ONLY valid JSON with this structure:
{"subject":"","totalQ":0,"mustPrepare":[],"predicted":[],"topics":[{"name":"","unit":"Unit N","frequency":0,"probability":0,"heat":"high/medium/low","questions":[{"text":"","marks":0,"years":[],"frequency":0,"insight":""}]}]}
Sort topics by probability desc. ${unit !== 'all' ? `Focus only on ${unit}.` : ''}`;
  const userMsg = `Analyse this PYQ for ${subject}. Return only JSON.`;
  try {
    let raw;
    if (pyqBase64) raw = await callClaude(sys, userMsg, true, pyqBase64);
    else raw = await callClaude(sys, `Analyse this PYQ for ${subject}:\n\n${pyqFileContent?.substring(0,12000)}\n\nReturn only JSON.`);
    raw = raw.replace(/```json\n?/g,'').replace(/```/g,'').trim();
    renderPYQ(JSON.parse(raw));
  } catch(e) {
    renderPYQ(getDemoPYQ(subject));
  }
  btnLoading('pyq-btn', false);
}
function renderPYQ(data) {
  const hc = {'high':'var(--red)','medium':'var(--amber)','low':'var(--hint)'};
  let html = `<div class="card" style="margin-bottom:14px">
    <div style="font-size:14px;font-weight:600;margin-bottom:8px">${data.subject} — ${data.totalQ} questions found</div>
    ${data.mustPrepare?.length ? `<div style="margin-bottom:10px"><div class="label">Must prepare</div><div style="display:flex;gap:6px;flex-wrap:wrap">${data.mustPrepare.map(t=>`<span class="tag tag-red">${t}</span>`).join('')}</div></div>` : ''}
    ${data.predicted?.length ? `<div><div class="label">Predicted for next exam</div><div style="display:flex;gap:6px;flex-wrap:wrap">${data.predicted.map(t=>`<span class="tag tag-green">${t}</span>`).join('')}</div></div>` : ''}
  </div>`;
  (data.topics||[]).forEach((t,ti) => {
    html += `<div style="margin-bottom:16px">
      <div class="topic-row" onclick="togglePYQTopic(${ti})">
        <span style="font-family:var(--mono);font-size:13px;font-weight:500">${t.name}</span>
        <span class="tag tag-muted" style="font-size:10px">${t.unit}</span>
        <div class="prob-bar-wrap"><div class="prob-bar" style="width:${t.probability||0}%;background:${hc[t.heat]||'var(--hint)'}"></div></div>
        <span style="font-family:var(--mono);font-size:12px;color:${hc[t.heat]||'var(--hint)'};min-width:36px;text-align:right">${t.probability}%</span>
        <span style="font-size:10px;padding:2px 7px;border-radius:4px;background:${hc[t.heat]+'20'||'var(--bg3)'};color:${hc[t.heat]||'var(--hint)'};font-family:var(--mono)">${(t.heat||'').toUpperCase()}</span>
      </div>
      <div class="topic-qs" id="pyq-topic-${ti}" style="display:none">
        ${(t.questions||[]).map((q,qi) => `
          <div class="qitem" onclick="this.classList.toggle('open')">
            <div class="qitem-text">${q.text}</div>
            <div class="qitem-meta">
              ${(q.years||[]).map(y=>`<span class="tag tag-muted">${y}</span>`).join('')}
              ${q.marks?`<span class="tag tag-amber">${q.marks}M</span>`:''}
              ${q.frequency>1?`<span class="tag tag-blue">×${q.frequency}</span>`:''}
            </div>
            <div class="qitem-insight">${q.insight||''}</div>
          </div>`).join('')}
      </div>
    </div>`;
  });
  document.getElementById('pyq-output').innerHTML = html;
}
function togglePYQTopic(i) {
  const el = document.getElementById('pyq-topic-' + i);
  el.style.display = el.style.display === 'none' ? 'flex' : 'none';
  el.style.flexDirection = 'column';
}
function getDemoPYQ(sub) {
  return { subject: sub||'Engineering Mechanics', totalQ:38, mustPrepare:['Friction','Moment of Inertia','Virtual Work','Truss Analysis'], predicted:['Friction on inclined plane','Composite MI','D\'Alembert'],
    topics:[
      {name:'Friction & Applications',unit:'Unit 2',frequency:9,probability:94,heat:'high',questions:[{text:'A 200N block on rough surface with μ=0.3. Find force to move it.',marks:10,years:['2023','2022','2021'],frequency:4,insight:'Appeared 4 years straight. Always numerical. Must solve.'},{text:'Explain laws of dry friction with diagrams.',marks:6,years:['2023','2021'],frequency:2,insight:'Theory + diagram. Easy 6 marks.'}]},
      {name:'Moment of Inertia',unit:'Unit 4',frequency:8,probability:88,heat:'high',questions:[{text:'Derive MI of solid cylinder about centroidal axis.',marks:10,years:['2023','2022','2021','2020'],frequency:5,insight:'Most repeated derivation. Memorise this.'},{text:'Find MI of T-section / I-section composite body.',marks:10,years:['2023','2021'],frequency:3,insight:'Composite section — alternates between T, I, L each year.'}]},
      {name:'Kinematics',unit:'Unit 5',frequency:5,probability:65,heat:'medium',questions:[{text:'Particle with a=4t-2. Find v and s at t=3s.',marks:8,years:['2022','2020'],frequency:2,insight:'Variable acceleration — integrate carefully.'}]},
    ]};
}

// ─────────────────────────────────────────────────────────────────────────────
// AI COACH
// ─────────────────────────────────────────────────────────────────────────────
const coachChips = ['Explain a concept simply','How to study for exams?','Make a quick revision plan','Best YouTube channels for engineering','What is the 50/30/20 rule for studying?','Help me understand this topic'];
function initCoach() {
  const msgs = document.getElementById('coach-msgs');
  if (!msgs.children.length) {
    addCoachMsg('ai', 'Hey! I\'m your AI study coach 👋\n\nI can help you understand tough concepts, make revision plans, find resources, decode exam patterns, or just answer any study-related question.\n\nWhat do you want to work on today?');
    document.getElementById('coach-chips').innerHTML = coachChips.map(c => `<button class="chip" onclick="coachChip('${c}')">${c}</button>`).join('');
  }
}
function addCoachMsg(role, text) {
  const msgs = document.getElementById('coach-msgs');
  const d = document.createElement('div');
  d.className = `cmsg ${role}`;
  d.innerHTML = `<div class="cmsg-avatar">${role==='ai'?'◎':'◷'}</div><div class="cmsg-bubble">${text.replace(/\n/g,'<br>')}</div>`;
  msgs.appendChild(d);
  msgs.scrollTop = msgs.scrollHeight;
}
function showTyping() {
  const msgs = document.getElementById('coach-msgs');
  const d = document.createElement('div');
  d.className = 'cmsg ai'; d.id = 'typing';
  d.innerHTML = `<div class="cmsg-avatar">◎</div><div class="cmsg-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
  msgs.appendChild(d); msgs.scrollTop = msgs.scrollHeight;
}
function removeTyping() { const t = document.getElementById('typing'); if(t) t.remove(); }
async function coachSend() {
  const inp = document.getElementById('coach-input');
  const text = inp.value.trim(); if (!text) return;
  inp.value = ''; inp.style.height = 'auto';
  addCoachMsg('user', text);
  coachHistory.push({ role: 'user', content: text });
  showTyping();
  const sys = `You are StudyOS AI Coach — an expert academic assistant for Indian engineering students (B.Tech, BE). You help with:
- Explaining engineering concepts clearly with examples
- Creating study plans and revision strategies  
- Answering questions about any subject (Maths, Physics, CS, Mechanical, Electrical, etc.)
- Career guidance for engineering students in India
- Exam tips for IPU, AKTU, Mumbai University, VTU etc.
Keep responses concise (4-6 lines), practical, and encouraging. Use Indian context. Format with line breaks for readability.`;
  try {
    const reply = await callClaudeChat(sys, coachHistory.slice(-8));
    removeTyping();
    addCoachMsg('ai', reply);
    coachHistory.push({ role: 'assistant', content: reply });
  } catch(e) {
    removeTyping();
    const fallbacks = {
      'concept': 'Break complex topics into 3 parts: definition, formula/rule, and one real example. Master each part separately before combining them.',
      'study': 'Use the 25-5 Pomodoro method: 25 mins focused study, 5 min break. After 4 rounds, take a 20 min break. This works better than studying for 3 hours straight.',
      'exam': 'For exam prep: Day 1-2 read all topics once. Day 3-4 solve PYQs. Day 5 revise formulas only. Day 6 rest and light revision. Sleep 7 hours before exam.',
    };
    const key = Object.keys(fallbacks).find(k => text.toLowerCase().includes(k)) || 'study';
    addCoachMsg('ai', fallbacks[key] + '\n\n(Tip: Set your API key to get full AI responses!)');
  }
}
function coachChip(text) {
  document.getElementById('coach-input').value = text;
  coachSend();
  document.getElementById('coach-chips').innerHTML = '';
}

// init
updateDashboard();
initCoach();
</script>
