    document.getElementById('schedule-output').innerHTML = `<div class="card" style="border-color:rgba(239,68,68,.2)"><div style="color:var(--red);font-size:13px">Error generating schedule. Check your API key and try again.</div></div>`;
  }
  btnLoading('sched-btn', false);
}
function renderSchedule(data) {
  const typeColors = { new: 'var(--blue)', revision: 'var(--amber)', practice: 'var(--green)' };
  let html = `<div class="card" style="border-color:rgba(167,139,250,.2);background:rgba(167,139,250,.04)">
    <div style="font-family:var(--mono);font-size:10px;color:var(--purple);letter-spacing:.1em;margin-bottom:6px">STRATEGY</div>
