// Claude API call helper
async function callClaude(system, userMsg, isDoc = false, docData = null) {
  if (!apiKey) { openModal(); throw new Error('No API key'); }
  let messages;
  if (isDoc && docData) {
    messages = [{ role: 'user', content: [
      { type: 'document', source: { type: 'base64', media_type: 'application/pdf', data: docData } },
      { type: 'text', text: userMsg }
    ]}];
  } else {
    messages = [{ role: 'user', content: userMsg }];
  }
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-api-key': apiKey },
    body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 4000, system, messages })
  });
  const data = await res.json();
  if (!data.content?.[0]) throw new Error('No response');
  return data.content[0].text;
}

async function callClaudeChat(system, history) {
  if (!apiKey) { openModal(); throw new Error('No API key'); }
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-api-key': apiKey },
    body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 600, system, messages: history })
  });
  const data = await res.json();
  return data.content[0].text;
}

function btnLoading(id, on) {
