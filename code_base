  const prompt = `Create a detailed day-by-day study schedule. Return ONLY valid JSON.
Subjects: ${JSON.stringify(subjectData)}
Start date: ${startDate}
Hours per day: ${hours}
Weak areas: ${weak || 'none specified'}

JSON structure:
{
  "totalDays": number,
  "strategy": "2-line study strategy tip",
  "days": [
    {
      "date": "YYYY-MM-DD",
      "dayName": "Monday",
      "totalHours": number,
