function updateDashboard() {
  const now = new Date();
  document.getElementById('dash-date').textContent = now.toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
  const pending = deadlines.filter(d => !d.done);
  const urgent = deadlines.filter(d => !d.done && daysLeft(d.date) <= 3);
  const done = deadlines.filter(d => d.done);
  const subjs = [...new Set(deadlines.map(d => d.subject).filter(Boolean))];
  document.getElementById('d-tasks').textContent = pending.length;
  document.getElementById('d-urgent').textContent = urgent.length;
  document.getElementById('d-done').textContent = done.length;
  document.getElementById('d-subjects').textContent = subjs.length;
  const el = document.getElementById('dash-deadlines');
  if (!pending.length) { el.innerHTML = '<div class="empty"><div class="empty-icon">◻</div><div class="empty-text">No pending deadlines — great!</div></div>'; return; }
  el.innerHTML = pending.slice(0,5).map(d => {
    const dl = daysLeft(d.date);
    const color = dl <= 1 ? 'var(--red)' : dl <= 3 ? 'var(--amber)' : 'var(--green)';
    return `<div class="today-item"><div class="today-dot" style="background:${color}"></div>
    <div class="today-text"><strong>${d.name}</strong> <span style="color:var(--muted);font-size:12px">· ${d.subject}</span></div>
    <div class="today-meta">${dl <= 0 ? 'Overdue' : dl === 1 ? 'Tomorrow' : `${dl}d left`}</div></div>`;
  }).join('');
}
function daysLeft(dateStr) {
  if (!dateStr) return 999;
  const diff = new Date(dateStr) - new Date();
  return Math.ceil(diff / 86400000);
}
updateDashboard();
document.getElementById('dash-date').textContent = new Date().toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric' });

