  ]
}
Include revision days before exams. Mark weak areas with more time. Keep it realistic.`;

  try {
    const raw = (await callClaude('You are an expert academic planner for Indian engineering students. Return only valid JSON.', prompt)).replace(/```json\n?/g,'').replace(/```/g,'').trim();
    const data = JSON.parse(raw);
