            </div>
            <div style="text-align:right">
              <div class="sched-time">${t.hours}h</div>
              <div style="font-size:10px;color:${typeColors[t.type]||'var(--muted)'};margin-top:2px;font-family:var(--mono)">${t.type||''}</div>
            </div>
          </div>`).join('')}
      </div>
    </div>`;
  });
  document.getElementById('schedule-output').innerHTML = html;
}

