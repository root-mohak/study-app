<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StudyOS — College Command Centre</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Familjen+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0e0e0e;--bg2:#161616;--bg3:#1e1e1e;--card:#1a1a1a;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#efefef;--muted:rgba(239,239,239,0.45);--hint:rgba(239,239,239,0.25);
  --green:#22c55e;--amber:#f59e0b;--red:#ef4444;--blue:#3b82f6;--purple:#a78bfa;
  --serif:'Instrument Serif',serif;--sans:'Familjen Grotesk',sans-serif;--mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;line-height:1.6;min-height:100vh;overflow-x:hidden}

/* ── SHELL ── */
.shell{display:grid;grid-template-columns:220px 1fr;min-height:100vh}

/* ── SIDEBAR ── */
.sidebar{background:var(--bg2);border-right:1px solid var(--border);padding:0;display:flex;flex-direction:column;position:sticky;top:0;height:100vh}
.brand{padding:22px 20px 16px;border-bottom:1px solid var(--border)}
.brand-name{font-family:var(--serif);font-size:22px;font-style:italic;color:var(--text);line-height:1}
.brand-sub{font-family:var(--mono);font-size:10px;color:var(--hint);letter-spacing:.1em;margin-top:3px}
.nav-section{padding:16px 12px 8px;font-family:var(--mono);font-size:10px;color:var(--hint);letter-spacing:.1em;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;cursor:pointer;margin:2px 8px;transition:all .2s;color:var(--muted);font-size:13px;font-weight:500}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{background:var(--text);color:var(--bg)}
.nav-icon{width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.sidebar-bottom{margin-top:auto;padding:16px;border-top:1px solid var(--border)}
.api-status{display:flex;align-items:center;gap:8px;padding:9px 12px;background:var(--bg3);border-radius:8px;cursor:pointer;transition:all .2s}
.api-status:hover{background:var(--border2)}
.api-dot{width:7px;height:7px;border-radius:50%;background:var(--hint);flex-shrink:0}
.api-dot.on{background:var(--green)}
.api-label{font-family:var(--mono);font-size:11px;color:var(--muted)}

/* ── MAIN ── */
.main{overflow-y:auto;min-height:100vh}
.page{display:none;animation:fadeUp .3s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.page-inner{max-width:900px;margin:0 auto;padding:36px 32px 60px}
.page-head{margin-bottom:32px}
.page-title{font-family:var(--serif);font-size:36px;font-style:italic;line-height:1.1;margin-bottom:6px}
.page-desc{color:var(--muted);font-size:14px}

/* ── COMPONENTS ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px 22px;margin-bottom:14px}
.card-title{font-size:13px;font-weight:600;margin-bottom:12px;color:var(--text)}
.label{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--hint);display:block;margin-bottom:6px}
input[type=text],input[type=date],input[type=number],textarea,select{
  width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;
  color:var(--text);font-family:var(--sans);font-size:13px;padding:9px 12px;
  outline:none;transition:border-color .2s;resize:vertical
}
input:focus,textarea:focus,select:focus{border-color:rgba(255,255,255,0.35)}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.field{margin-bottom:14px}
.btn{display:inline-flex;align-items:center;gap:7px;padding:10px 20px;border-radius:8px;border:none;font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;transition:all .2s}
.btn-primary{background:var(--text);color:var(--bg)}
.btn-primary:hover{background:#d0d0d0;transform:translateY(-1px)}
.btn-ghost{background:var(--bg3);color:var(--text);border:1px solid var(--border2)}
.btn-ghost:hover{border-color:rgba(255,255,255,0.3)}
.btn-danger{background:rgba(239,68,68,.12);color:var(--red);border:1px solid rgba(239,68,68,.2)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important}
.spinner-inline{width:14px;height:14px;border:2px solid rgba(0,0,0,.2);border-top-color:var(--bg);border-radius:50%;animation:spin .6s linear infinite;display:none}
.loading .spinner-inline{display:block}
.loading .btn-label{opacity:.5}
@keyframes spin{to{transform:rotate(360deg)}}
.tag{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:4px;font-family:var(--mono);font-size:11px}
.tag-green{background:rgba(34,197,94,.1);color:var(--green)}
.tag-amber{background:rgba(245,158,11,.1);color:var(--amber)}
.tag-red{background:rgba(239,68,68,.1);color:var(--red)}
.tag-blue{background:rgba(59,130,246,.1);color:var(--blue)}
.tag-purple{background:rgba(167,139,250,.1);color:var(--purple)}
.tag-muted{background:var(--bg3);color:var(--muted)}
.divider{border:none;border-top:1px solid var(--border);margin:20px 0}
.empty{text-align:center;padding:48px 24px;color:var(--hint)}
.empty-icon{font-size:32px;margin-bottom:12px;opacity:.4}
.empty-text{font-size:13px}

/* ── DASHBOARD ── */
.dash-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:24px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px 20px}
.stat-val{font-family:var(--mono);font-size:28px;font-weight:500;line-height:1;margin-bottom:4px}
.stat-lbl{font-size:12px;color:var(--muted)}
.today-list{display:flex;flex-direction:column;gap:8px}
.today-item{display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--bg3);border-radius:8px;border:1px solid var(--border)}
.today-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.today-text{font-size:13px;flex:1}
.today-meta{font-family:var(--mono);font-size:11px;color:var(--hint)}

/* ── SCHEDULE ── */
.subject-row{display:grid;grid-template-columns:1fr 160px 100px 36px;gap:8px;align-items:center;margin-bottom:8px}
.day-block{border:1px solid var(--border);border-radius:10px;margin-bottom:12px;overflow:hidden}
.day-header{background:var(--bg3);padding:10px 16px;display:flex;align-items:center;justify-content:space-between}
.day-name{font-family:var(--mono);font-size:12px;font-weight:500}
.day-date{font-family:var(--mono);font-size:11px;color:var(--hint)}
.day-tasks{padding:12px 16px;display:flex;flex-direction:column;gap:8px}
.sched-task{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border-radius:8px;background:var(--bg2)}
.sched-subject{font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:4px;background:rgba(167,139,250,.12);color:var(--purple);white-space:nowrap}
.sched-topic{font-size:13px;flex:1;line-height:1.4}
.sched-time{font-family:var(--mono);font-size:11px;color:var(--hint);white-space:nowrap}
.sched-tip{font-size:12px;color:var(--muted);margin-top:4px;font-style:italic}

/* ── RESOURCES ── */
.resource-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 18px;margin-bottom:10px;transition:all .2s}
.resource-card:hover{border-color:var(--border2);transform:translateX(3px)}
.resource-head{display:flex;align-items:flex-start;gap:12px;margin-bottom:6px}
.resource-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.resource-title{font-size:14px;font-weight:600;margin-bottom:2px}
.resource-meta{font-size:12px;color:var(--muted)}
.resource-desc{font-size:13px;color:var(--muted);line-height:1.55;margin-bottom:10px}
.resource-link{font-family:var(--mono);font-size:11px;color:var(--blue);text-decoration:none;word-break:break-all}
.resource-link:hover{text-decoration:underline}

/* ── DEADLINES ── */
.deadline-row{display:flex;align-items:center;gap:12px;padding:12px 16px;background:var(--card);border:1px solid var(--border);border-radius:10px;margin-bottom:8px;transition:all .2s}
.deadline-row.done{opacity:.4}
.deadline-check{width:18px;height:18px;border-radius:4px;border:1.5px solid var(--border2);cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s}
.deadline-check.checked{background:var(--green);border-color:var(--green)}
.deadline-info{flex:1}
.deadline-name{font-size:13px;font-weight:500}
.deadline-sub{font-size:12px;color:var(--muted);margin-top:1px}
.deadline-date{font-family:var(--mono);font-size:11px;text-align:right}
.deadline-del{background:none;border:none;color:var(--hint);cursor:pointer;font-size:14px;padding:4px;transition:color .2s}
.deadline-del:hover{color:var(--red)}
.urgency-bar{height:3px;border-radius:2px;margin-top:6px}

/* ── AI COACH ── */
.coach-wrap{display:flex;flex-direction:column;height:calc(100vh - 140px);max-height:700px}
.coach-msgs{flex:1;overflow-y:auto;padding:4px 0;display:flex;flex-direction:column;gap:14px;margin-bottom:16px}
.coach-msgs::-webkit-scrollbar{width:3px}
.coach-msgs::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.cmsg{display:flex;gap:10px;align-items:flex-start}
.cmsg.user{flex-direction:row-reverse}
.cmsg-avatar{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;background:var(--bg3)}
.cmsg.ai .cmsg-avatar{background:rgba(167,139,250,.15)}
.cmsg-bubble{max-width:80%;padding:11px 14px;border-radius:10px;font-size:13px;line-height:1.65}
.cmsg.ai .cmsg-bubble{background:var(--card);border:1px solid var(--border);border-radius:4px 10px 10px 10px}
.cmsg.user .cmsg-bubble{background:rgba(255,255,255,.07);border:1px solid var(--border2);border-radius:10px 4px 10px 10px}
.typing-dots{display:flex;gap:4px;padding:4px 0}
.typing-dots span{width:5px;height:5px;border-radius:50%;background:var(--muted);animation:bounce 1.1s infinite}
.typing-dots span:nth-child(2){animation-delay:.18s}
.typing-dots span:nth-child(3){animation-delay:.36s}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
.coach-input-row{display:flex;gap:8px;align-items:flex-end}
.coach-textarea{flex:1;min-height:44px;max-height:120px;resize:none;border-radius:10px;background:var(--bg3)}
.coach-send{width:44px;height:44px;background:var(--text);border:none;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.coach-send:hover{background:#d0d0d0;transform:scale(1.05)}
.coach-send svg{width:16px;height:16px;fill:var(--bg)}
.chip-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.chip{background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:5px 12px;font-size:11px;color:var(--muted);cursor:pointer;transition:all .2s;font-family:var(--mono)}
.chip:hover{border-color:var(--border2);color:var(--text)}

/* ── PYQ (embedded) ── */
.upload-zone{border:1.5px dashed var(--border2);border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:all .25s;position:relative;overflow:hidden}
.upload-zone:hover{border-color:rgba(255,255,255,.3)}
.upload-zone.has-file{border-color:var(--green);border-style:solid;background:rgba(34,197,94,.04)}
#pyq-file{position:absolute;inset:0;opacity:0;cursor:pointer}
.prob-bar-wrap{flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.prob-bar{height:100%;border-radius:3px;transition:width .6s ease}
.topic-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;cursor:pointer}
.topic-qs{padding-left:0;display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
.qitem{background:var(--bg3);border-radius:8px;padding:11px 14px;border:1px solid var(--border);cursor:pointer}
.qitem:hover{border-color:var(--border2)}
.qitem-text{font-size:13px;line-height:1.5}
.qitem-meta{display:flex;gap:8px;margin-top:6px;flex-wrap:wrap}
.qitem-insight{font-size:12px;color:var(--muted);margin-top:8px;padding-top:8px;border-top:1px solid var(--border);display:none;line-height:1.55}
.qitem.open .qitem-insight{display:block}

/* ── MODAL ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px)}
.overlay.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:14px;padding:28px;max-width:400px;width:92%}
.modal h3{font-family:var(--serif);font-size:22px;font-style:italic;margin-bottom:6px}
.modal p{font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.6}
.modal-btns{display:flex;gap:8px;margin-top:16px}

@media(max-width:700px){
  .shell{grid-template-columns:1fr}
  .sidebar{position:relative;height:auto;flex-direction:row;flex-wrap:wrap;gap:0;border-right:none;border-bottom:1px solid var(--border)}
  .brand{border-bottom:none;padding:14px 16px}
  .nav-item{padding:8px 10px;font-size:12px}
  .nav-section{display:none}
  .sidebar-bottom{border-top:none;padding:8px 12px;margin-top:0}
  .page-inner{padding:20px 16px 40px}
  .grid2,.grid3{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- API MODAL -->
<div class="overlay" id="modal">
  <div class="modal">
    <h3>Claude API Key</h3>
    <p>Required for AI features (schedule generator, resource finder, AI coach, PYQ analyser). Get a free key at <strong>console.anthropic.com</strong>. Stored only in your browser.</p>
    <input type="text" id="api-input" placeholder="sk-ant-api03-..." style="margin-bottom:0">
    <div class="modal-btns">
      <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveKey()">Save Key</button>
    </div>
  </div>
</div>

<div class="shell">
<!-- ── SIDEBAR ── -->
<div class="sidebar">
  <div class="brand">
    <div class="brand-name">StudyOS</div>
    <div class="brand-sub">College Command Centre</div>
  </div>
  <div class="nav-section">Tools</div>
  <div class="nav-item active" onclick="nav('dashboard')"><span class="nav-icon">⊞</span>Dashboard</div>
  <div class="nav-item" onclick="nav('schedule')"><span class="nav-icon">◷</span>Study Planner</div>
  <div class="nav-item" onclick="nav('resources')"><span class="nav-icon">◈</span>Resources</div>
  <div class="nav-item" onclick="nav('deadlines')"><span class="nav-icon">◻</span>Deadlines</div>
  <div class="nav-item" onclick="nav('pyq')"><span class="nav-icon">◑</span>PYQ Analyser</div>
  <div class="nav-item" onclick="nav('coach')"><span class="nav-icon">◎</span>AI Coach</div>
  <div class="sidebar-bottom">
    <div class="api-status" onclick="openModal()" id="api-status">
      <div class="api-dot" id="api-dot"></div>
      <span class="api-label" id="api-label">Set API Key</span>
    </div>
  </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="main">

<!-- DASHBOARD -->
<div class="page active" id="page-dashboard">
<div class="page-inner">
  <div class="page-head">
    <div class="page-title">Good day, student.</div>
    <div class="page-desc" id="dash-date"></div>
  </div>
  <div class="dash-grid">
    <div class="stat-card"><div class="stat-val" id="d-tasks" style="color:var(--amber)">0</div><div class="stat-lbl">Pending deadlines</div></div>
    <div class="stat-card"><div class="stat-val" id="d-urgent" style="color:var(--red)">0</div><div class="stat-lbl">Due in 3 days</div></div>
    <div class="stat-card"><div class="stat-val" id="d-done" style="color:var(--green)">0</div><div class="stat-lbl">Completed tasks</div></div>
    <div class="stat-card"><div class="stat-val" id="d-subjects" style="color:var(--purple)">0</div><div class="stat-lbl">Subjects tracked</div></div>
  </div>
  <div class="card">
    <div class="card-title">Upcoming deadlines</div>
    <div id="dash-deadlines"><div class="empty"><div class="empty-icon">◻</div><div class="empty-text">No deadlines yet — add them in the Deadlines tab</div></div></div>
  </div>
  <div class="card" style="margin-top:14px">
    <div class="card-title">Quick actions</div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <button class="btn btn-ghost" onclick="nav('schedule')">◷ Generate study plan</button>
      <button class="btn btn-ghost" onclick="nav('deadlines')">＋ Add deadline</button>
      <button class="btn btn-ghost" onclick="nav('resources')">◈ Find resources</button>
      <button class="btn btn-ghost" onclick="nav('pyq')">◑ Analyse PYQ</button>
    </div>
  </div>
</div>
</div>

<!-- STUDY PLANNER -->
<div class="page" id="page-schedule">
<div class="page-inner">
  <div class="page-head">
    <div class="page-title">Study Planner</div>
    <div class="page-desc">Enter your subjects and exam dates — AI builds a smart day-by-day schedule</div>
  </div>
  <div class="card">
    <div class="card-title">Your subjects</div>
    <div id="subject-rows"></div>
    <button class="btn btn-ghost" onclick="addSubjectRow()" style="margin-top:4px">＋ Add subject</button>
  </div>
  <div class="card">
    <div class="grid2">
      <div class="field">
        <label class="label">Study start date</label>
        <input type="date" id="start-date">
      </div>
      <div class="field">
        <label class="label">Hours available per day</label>
        <input type="number" id="hours-day" value="4" min="1" max="12">
      </div>
    </div>
    <div class="field">
      <label class="label">Weak areas / topics to focus more</label>
      <input type="text" id="weak-areas" placeholder="e.g. Integration, Pointers, Thermodynamics...">
    </div>
    <button class="btn btn-primary" id="sched-btn" onclick="generateSchedule()">
      <div class="spinner-inline"></div>
      <span class="btn-label">Generate Schedule →</span>
    </button>
  </div>
  <div id="schedule-output"></div>
</div>
</div>

<!-- RESOURCES -->
<div class="page" id="page-resources">
<div class="page-inner">
  <div class="page-head">
    <div class="page-title">Resource Finder</div>
    <div class="page-desc">Type any topic — get the best YouTube videos, notes, books and practice links instantly</div>
  </div>
  <div class="card">
    <div class="grid2" style="margin-bottom:12px">
      <div class="field" style="margin:0">
        <label class="label">Topic or subject</label>
        <input type="text" id="res-topic" placeholder="e.g. Moment of Inertia, OS Scheduling, PN Junction...">
      </div>
      <div class="field" style="margin:0">
        <label class="label">Difficulty level</label>
        <select id="res-level">
          <option value="beginner">Beginner — basics from scratch</option>
          <option value="intermediate" selected>Intermediate — exam level</option>
          <option value="advanced">Advanced — deep understanding</option>
        </select>
      </div>
    </div>
    <div class="field">
      <label class="label">Resource type (optional)</label>
      <div style="display:flex;gap:8px;flex-wrap:wrap" id="res-type-tags">
        <span class="chip active-chip" data-type="all" onclick="toggleChip(this)" style="background:var(--text);color:var(--bg);border-color:var(--text)">All</span>
        <span class="chip" data-type="video" onclick="toggleChip(this)">YouTube</span>
        <span class="chip" data-type="notes" onclick="toggleChip(this)">Notes/PDF</span>
        <span class="chip" data-type="book" onclick="toggleChip(this)">Books</span>
        <span class="chip" data-type="practice" onclick="toggleChip(this)">Practice</span>
      </div>
    </div>
    <button class="btn btn-primary" id="res-btn" onclick="findResources()">
      <div class="spinner-inline"></div>
      <span class="btn-label">Find Resources →</span>
    </button>
  </div>
  <div id="resources-output"></div>
</div>
</div>

<!-- DEADLINES -->
<div class="page" id="page-deadlines">
<div class="page-inner">
  <div class="page-head">
    <div class="page-title">Deadlines & Tasks</div>
    <div class="page-desc">Track assignments, exams, projects — never miss a deadline again</div>
  </div>
  <div class="card">
    <div class="grid3" style="margin-bottom:12px">
      <div class="field" style="margin:0">
        <label class="label">Task name</label>
        <input type="text" id="task-name" placeholder="e.g. DSA Assignment 2">
      </div>
      <div class="field" style="margin:0">
        <label class="label">Subject</label>
        <input type="text" id="task-subject" placeholder="e.g. Data Structures">
      </div>
      <div class="field" style="margin:0">
        <label class="label">Due date</label>
        <input type="date" id="task-date">
      </div>
    </div>
